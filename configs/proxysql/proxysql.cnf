datadir="/var/lib/proxysql"

admin_variables=
{
    admin_credentials="admin:admin"
    mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
    threads=4
    max_connections=2048
    interfaces="0.0.0.0:3306"
    default_schema=""
    server_version="8.0.27"
    connect_timeout_server=3000
    monitor_enabled=false
    multiplexing=0
    monitor_username="dvwa"
    monitor_password="dvwapass"
    monitor_connect_interval=60000
    monitor_ping_interval=10000
    ping_interval_server_msec=120000
    ping_timeout_server=500
    have_ssl=false
}

mysql_servers=
(
    {
        address="10.0.30.10"
        port=3306
        hostgroup=0
        status="ONLINE"
        weight=1
        compression=0
        max_connections=100
    }
)

mysql_users=
(
    {
        username="dvwa"
        password="dvwapass"
        default_hostgroup=0
        transaction_persistent=1
        active=1
    },
    {
        username="root"
        password="rootpass"
        default_hostgroup=0
        transaction_persistent=1
        active=1
    }
)

mysql_query_rules=
(
)
