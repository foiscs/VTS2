[mysqld]
# 펜테스트 랩 전용 — 취약한 설정
bind-address        = 0.0.0.0
skip-host-cache
skip-name-resolve

# UDF privesc 시나리오용: secure-file-priv 해제
secure-file-priv    = ""

# LOAD DATA LOCAL INFILE 허용 (SQLi 데이터 유출 시나리오)
local-infile        = 1

# 쿼리 로그 (포렌식/분석용)
general_log         = 1
general_log_file    = /var/lib/mysql/general.log

# MySQL 8.0 호환성: native password 플러그인 기본 사용
default-authentication-plugin = mysql_native_password
